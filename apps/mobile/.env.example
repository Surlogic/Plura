# Mobile (Expo)
# Obligatoria fuera de desarrollo. En release la app falla temprano si falta.
EXPO_PUBLIC_API_URL=http://10.0.2.2:3000
EXPO_PUBLIC_MAPBOX_TOKEN=
# Fallback legacy para entornos locales que aun lo usen
MAPBOX_TOKEN=

# Google OAuth
# Expo Go is not supported for Google OAuth in Expo SDK 54+.
# Use a development build and configure the native client IDs.
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# Native builds (recommended for release)
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=

# Web OAuth client ID (used in code exchange flows/backends)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# Legacy fallback (optional)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
