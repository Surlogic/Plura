{
  "expo": {
    "name": "mobile",
    "slug": "mobile",
    "scheme": "plura",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1EB"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plura.mobile"
    },
    "android": {
      "package": "com.plura.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1EB"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Plura usa tu ubicacion para mostrar profesionales cercanos y ordenar resultados por distancia."
        }
      ],
      "expo-notifications",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "fbc84990-193c-40c7-b82b-d4e617ab8b35"
      }
    }
  }
}
