@startuml "Plura - Entity Relationships"

!theme plain
left to right direction
skinparam linetype ortho
skinparam classAttributeIconSize 0
skinparam defaultFontSize 11

title Plura Backend - Core Persistence Model

package "Identity & Auth" #E8F5E9 {
  entity User {
    **id** : Long <<PK>>
    --
    fullName : String
    email : String <<unique>>
    phoneNumber : String
    password : String (hashed)
    provider : String
    providerId : String
    role : Enum {USER, PROFESSIONAL}
    sessionVersion : Integer
    lastLoginAt : LocalDateTime
    emailVerifiedAt : LocalDateTime
    phoneVerifiedAt : LocalDateTime
    deletedAt : LocalDateTime
  }

  entity AuthSession {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    sessionType : Enum {WEB, MOBILE}
    refreshTokenHash : String <<unique>>
    previousRefreshTokenHash : String
    deviceLabel : String
    userAgent : String
    ipAddress : String
    expiresAt : LocalDateTime
    revokedAt : LocalDateTime
    refreshRotatedAt : LocalDateTime
    compromiseDetectedAt : LocalDateTime
  }

  entity RefreshToken {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    token : String <<unique>>
    expiryDate : LocalDateTime
    revokedAt : LocalDateTime
  }

  entity PasswordResetToken {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    tokenHash : String
    expiresAt : LocalDateTime
    consumedAt : LocalDateTime
  }

  entity EmailVerificationChallenge {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    codeHash : String
    expiresAt : LocalDateTime
    consumedAt : LocalDateTime
  }

  entity PhoneVerificationChallenge {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    codeHash : String
    expiresAt : LocalDateTime
    consumedAt : LocalDateTime
  }

  entity AuthOtpChallenge {
    **id** : String <<PK>>
    --
    user_id : Long <<FK>>
    purpose : Enum
    channel : Enum
    codeHash : String
    expiresAt : LocalDateTime
    consumedAt : LocalDateTime
  }

  entity AuthAuditLog {
    **id** : Long <<PK>>
    --
    user_id : Long <<FK>>
    eventType : Enum
    status : Enum
    sessionId : String
    ipAddress : String
    userAgent : String
    metadataJson : text
    createdAt : LocalDateTime
  }
}

package "Professional Catalog" #E3F2FD {
  entity ProfessionalProfile {
    **id** : Long <<PK>>
    --
    user_id : Long <<FK, unique>>
    rubro : String
    displayName : String
    slug : String <<unique>>
    publicHeadline : String
    publicAbout : text
    location / country / city : String
    fullAddress : String
    latitude / longitude : Double
    rating : Double
    reviewsCount : Integer
    tipoCliente : String
    scheduleJson : text
    slotDurationMinutes : Integer
    hasAvailabilityToday : Boolean
    nextAvailableAt : LocalDateTime
    active : Boolean
  }

  entity ProfesionalService {
    **id** : String <<PK>>
    --
    professional_id : Long <<FK>>
    category_id : UUID <<FK>>
    name : String
    description : String
    price : String
    duration : String
    imageUrl : String
    postBufferMinutes : Integer
    depositAmount : BigDecimal
    currency : String
    paymentType : Enum {ON_SITE, DEPOSIT, FULL_PREPAY}
    active : Boolean
  }

  entity Category {
    **id** : UUID <<PK>>
    --
    name : String
    slug : String
    imageUrl : String
    active : Boolean
  }

  entity BusinessPhoto {
    **id** : Long <<PK>>
    --
    professional_id : Long <<FK>>
    type : Enum
    url : String
    position : Integer
  }

  entity BookingPolicy {
    **id** : String <<PK>>
    --
    professional_id : Long <<unique>>
    allowClientCancellation : Boolean
    allowClientReschedule : Boolean
    cancellationWindowHours : Integer
    rescheduleWindowHours : Integer
    maxClientReschedules : Integer
    lateCancellationRefundMode : Enum
    lateCancellationRefundValue : BigDecimal
    version : Long
  }

  entity AvailableSlot {
    **id** : Long <<PK>>
    --
    professional_id : Long <<FK>>
    startAt : LocalDateTime
    endAt : LocalDateTime
    status : Enum {AVAILABLE, BOOKED, UNAVAILABLE}
  }

  entity ClientFavoriteProfessional {
    **id** : Long <<PK>>
    --
    client_user_id : Long <<FK>>
    professional_id : Long <<FK>>
    createdAt : LocalDateTime
  }
}

package "Bookings, Billing & Payments" #FFF3E0 {
  entity Booking {
    **id** : Long <<PK>>
    --
    user_id : Long <<FK>>
    professional_id : Long
    service_id : String
    startDateTime : LocalDateTime
    startDateTimeUtc : Instant
    operationalStatus : Enum
    timezone : String
    rescheduleCount : Integer
    cancelledAt / completedAt / noShowMarkedAt : LocalDateTime
    serviceNameSnapshot : String
    professionalSlugSnapshot : String
    professionalDisplayNameSnapshot : String
    professionalLocationSnapshot : String
    servicePriceSnapshot : BigDecimal
    serviceDepositAmountSnapshot : BigDecimal
    serviceCurrencySnapshot : String
    serviceDurationSnapshot : String
    servicePostBufferMinutesSnapshot : Integer
    servicePaymentTypeSnapshot : Enum
    policySnapshotJson : text
    version : Long
  }

  entity BookingActionDecision {
    **id** : String <<PK>>
    --
    booking_id : Long <<FK>>
    actionType : Enum
    actorType : Enum
    actorUserId : Long
    statusBefore / statusAfter : Enum
    refundPreviewAmount : BigDecimal
    retainPreviewAmount : BigDecimal
    financialOutcomeCode : String
    reasonCodesJson : text
    decisionSnapshotJson : text
  }

  entity BookingEvent {
    **id** : String <<PK>>
    --
    booking_id : Long <<FK>>
    eventType : Enum
    actorType : Enum
    actorUserId : Long
    payloadJson : text
    createdAt : LocalDateTime
  }

  entity BookingFinancialSummary {
    **id** : Long <<PK>>
    --
    booking_id : Long <<FK, unique>>
    amountCharged : BigDecimal
    amountHeld : BigDecimal
    amountToRefund : BigDecimal
    amountRefunded : BigDecimal
    amountToRelease : BigDecimal
    amountReleased : BigDecimal
    currency : String
    financialStatus : Enum
    lastDecisionId : String
    version : Long
  }

  entity BookingRefundRecord {
    **id** : String <<PK>>
    --
    booking_id : Long <<FK>>
    actorType : Enum
    actorUserId : Long
    requestedAmount : BigDecimal
    targetAmount : BigDecimal
    status : Enum
    reasonCode : Enum
    providerReference : String
    relatedDecisionId : String
  }

  entity BookingPayoutRecord {
    **id** : String <<PK>>
    --
    booking_id : Long <<FK>>
    professional_id : Long
    targetAmount : BigDecimal
    releasedAmount : BigDecimal
    status : Enum
    reasonCode : Enum
    provider : Enum
    providerReference : String
    relatedDecisionId : String
  }

  entity Subscription {
    **id** : String <<PK>>
    --
    professional_id : Long <<unique>>
    plan : Enum {PLAN_BASIC, PLAN_PROFESIONAL, PLAN_ENTERPRISE}
    status : Enum {TRIAL, ACTIVE, PAST_DUE, CANCELLED}
    provider : Enum
    providerSubscriptionId : String
    providerCustomerId : String
    currentPeriodStart : LocalDateTime
    currentPeriodEnd : LocalDateTime
    cancelAtPeriodEnd : Boolean
    planAmount / expectedAmount : BigDecimal
    currency / expectedCurrency : String
  }

  entity ProfessionalPaymentProviderConnection {
    **id** : String <<PK>>
    --
    professional_id : Long
    provider : Enum
    status : Enum
    providerAccountId : String
    providerUserId : String
    accessTokenEncrypted : text
    refreshTokenEncrypted : text
    tokenExpiresAt : LocalDateTime
    connectedAt : LocalDateTime
    disconnectedAt : LocalDateTime
    lastSyncAt : LocalDateTime
    lastError : String
    metadataJson : text
  }

  entity PaymentTransaction {
    **id** : String <<PK>>
    --
    professional_id : Long
    subscription_id : String <<FK>>
    booking_id : Long <<FK>>
    refund_record_id : String <<FK>>
    payout_record_id : String <<FK>>
    transactionType : Enum
    provider : Enum
    providerPaymentId : String
    externalReference : String
    amount : BigDecimal
    currency : String
    status : Enum
    providerStatus : String
  }

  entity PaymentEvent {
    **id** : String <<PK>>
    --
    provider : Enum
    providerEventId : String
    providerObjectId : String
    eventType : String
    payloadHash : String
    professional_id : Long
    booking_id : Long <<FK>>
    refund_record_id : String <<FK>>
    payout_record_id : String <<FK>>
    payment_transaction_id : String <<FK>>
    processed : Boolean
    processedAt : LocalDateTime
  }
}

package "Notifications & Reviews" #F3E5F5 {
  entity NotificationEvent {
    **id** : String <<PK>>
    --
    eventUuid : String <<unique>>
    eventType : Enum
    aggregateType : Enum
    aggregateId : String
    sourceModule : String
    sourceAction : String
    recipientType : Enum
    recipientId : String
    actorType : Enum
    actorId : String
    bookingReferenceId : Long
    payloadJson : text
    dedupeKey : String <<unique>>
    occurredAt : LocalDateTime
  }

  entity AppNotification {
    **id** : String <<PK>>
    --
    notification_event_id : String <<FK, unique>>
    recipientType : Enum
    recipientId : String
    title : String
    body : text
    severity : Enum
    category : String
    actionUrl : String
    actionLabel : String
    readAt : LocalDateTime
    archivedAt : LocalDateTime
  }

  entity EmailDispatch {
    **id** : String <<PK>>
    --
    notification_event_id : String <<FK, unique>>
    recipientEmail : String
    templateKey : String
    subject : String
    status : Enum
    attemptCount : Integer
    nextAttemptAt : LocalDateTime
    providerMessageId : String
    errorCode : String
  }

  entity BookingReview {
    **id** : Long <<PK>>
    --
    booking_id : Long <<FK, unique>>
    professional_id : Long <<FK>>
    user_id : Long <<FK>>
    rating : Integer
    reviewText : text
    businessReplyText : text
    businessRepliedAt : LocalDateTime
    businessRepliedByUserId : Long
    version : Long
  }
}

User ||--o{ AuthSession
User ||--o{ RefreshToken
User ||--o{ PasswordResetToken
User ||--o{ EmailVerificationChallenge
User ||--o{ PhoneVerificationChallenge
User ||--o{ AuthOtpChallenge
User ||--o{ AuthAuditLog

User ||--|| ProfessionalProfile
ProfessionalProfile ||--o{ ProfesionalService
ProfessionalProfile }o--o{ Category : professional_categories
ProfessionalProfile ||--o{ BusinessPhoto
ProfessionalProfile ||--o{ AvailableSlot
ProfessionalProfile ||..|| BookingPolicy : professional_id
ProfessionalProfile ||..|| Subscription : professional_id
ProfessionalProfile ||..o{ ProfessionalPaymentProviderConnection : professional_id
ProfessionalProfile ||--o{ ClientFavoriteProfessional

User ||--o{ ClientFavoriteProfessional
User ||--o{ Booking
ProfessionalProfile ||..o{ Booking : professional_id
ProfesionalService ||..o{ Booking : service snapshot

Booking ||--o{ BookingActionDecision
Booking ||--o{ BookingEvent
Booking ||--|| BookingFinancialSummary
Booking ||--o{ BookingRefundRecord
Booking ||--o{ BookingPayoutRecord
Booking ||--|| BookingReview

Subscription ||--o{ PaymentTransaction
Booking ||--o{ PaymentTransaction
BookingRefundRecord ||--o{ PaymentTransaction
BookingPayoutRecord ||--o{ PaymentTransaction

Booking ||--o{ PaymentEvent
PaymentTransaction ||--o{ PaymentEvent
BookingRefundRecord ||--o{ PaymentEvent
BookingPayoutRecord ||--o{ PaymentEvent

NotificationEvent ||--|| AppNotification
NotificationEvent ||--|| EmailDispatch
Booking ||..o{ NotificationEvent : bookingReferenceId
User ||--o{ BookingReview
ProfessionalProfile ||--o{ BookingReview

@enduml
