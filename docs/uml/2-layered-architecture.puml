@startuml "Plura - Layered Architecture"

!theme plain
skinparam defaultFontSize 11
skinparam packageStyle rectangle

title Plura Backend — Layered Architecture Diagram

' ════════════════════════════════
' PRESENTATION LAYER (Controllers)
' ════════════════════════════════
package "Presentation Layer (Controllers)" #E8F5E9 {

  package "Public API" #C8E6C9 {
    [ProfessionalPublicController\n/public/profesional] as PubProf
    [SearchController\n/api/search] as Search
    [CategoryController\n/api/categories] as CatCtrl
    [HomeController\n/api/home] as Home
    [GeoController\n/api/geo] as Geo
    [HealthController\n/health] as Health
  }

  package "Auth API" #DCEDC8 {
    [AuthController\n/auth/**] as Auth
  }

  package "Client API" #C5E1A5 {
    [BookingClientController\n/cliente/booking] as BookClient
    [BookingActionsController\n/cliente/booking/{id}/actions] as BookActions
    [ClientFavoriteController\n/cliente/favorite] as Fav
  }

  package "Professional API" #AED581 {
    [ProfessionalBookingCommandController\n/profesional/booking] as ProfBook
    [ProfesionalConfigController\n/profesional/config] as ProfConfig
  }

  package "Billing API" #F0F4C3 {
    [BillingController\n/billing] as Billing
    [BillingWebhookController\n/webhooks] as Webhooks
    [BookingPaymentController\n/booking/payment] as BookPay
  }

  package "Internal Ops API" #FFF9C4 {
    [InternalBookingOpsController\n/internal/ops/booking] as IntBook
    [InternalProviderOperationOpsController\n/internal/ops/billing] as IntBill
  }
}

' ════════════════════════════════
' SECURITY / MIDDLEWARE LAYER
' ════════════════════════════════
package "Security & Middleware" #FFF3E0 {
  [InternalOpsActuatorAccessFilter] as OpsFilter
  [CookieOriginProtectionFilter] as CookieFilter
  [JwtAuthenticationFilter] as JwtFilter
  [RateLimitingFilter] as RateFilter
  [GlobalExceptionHandler] as ErrHandler
}

' ════════════════════════════════
' SERVICE LAYER
' ════════════════════════════════
package "Service Layer (Business Logic)" #E3F2FD {

  package "Auth Services" #BBDEFB {
    [AuthService] as AuthSvc
    [SessionService] as SessSvc
    [PasswordLifecycleService] as PwdSvc
    [EmailVerificationService] as EmailSvc
    [PhoneVerificationService] as PhoneSvc
    [OtpChallengeService] as OtpSvc
    [AuthAuditService] as AuditSvc
    [AccountDeletionService] as DelSvc
  }

  package "Booking Services" #90CAF9 {
    [BookingClientService] as BookCSvc
    [BookingActionsService] as BookASvc
    [BookingEventService] as BookEvSvc
    [BookingFinanceService] as BookFinSvc
    [BookingProviderIntegrationService] as BookProvSvc
    [BookingDateTimeService] as BookDTSvc
    [BookingActionDecisionService] as BookDecSvc
  }

  package "Billing Services" #64B5F6 {
    [BillingService] as BillSvc
    [MercadoPagoSubscriptionService] as MPSvc
    [BillingWebhookService] as WHSvc
    [PaymentEventLedgerService] as LedgerSvc
  }

  package "Professional Services" #42A5F5 {
    [ProfessionalProfileService] as ProfSvc
    [ScheduleService] as SchedSvc
    [CategoryService] as CatSvc
  }

  package "Availability Services" #1E88E5 {
    [AvailableSlotService] as SlotSvc
    [ScheduleSummaryService] as SumSvc
  }

  package "Search Services" #1565C0 {
    [SearchService] as SearchSvc
    [SearchIndexService] as IdxSvc
    [SearchIndexWorker] as IdxWorker
  }

  package "Storage Services" #0D47A1 {
    [ImageStorageService] as ImgSvc
    [CloudflareR2ImageStorageService] as R2Svc
    [LocalImageStorageService] as LocalSvc
  }
}

' ════════════════════════════════
' CACHE LAYER
' ════════════════════════════════
package "Cache Layer" #F3E5F5 {
  [SearchCacheService] as SCache
  [ProfileCacheService] as PCache
  [SlotCacheService] as SlCache
}

' ════════════════════════════════
' PERSISTENCE LAYER
' ════════════════════════════════
package "Persistence Layer (Repositories)" #FFEBEE {
  [UserRepository] as UserRepo
  [AuthSessionRepository] as SessRepo
  [ProfessionalProfileRepository] as ProfRepo
  [ProfesionalServiceRepository] as SvcRepo
  [BookingRepository] as BookRepo
  [AvailableSlotRepository] as SlotRepo
  [CategoryRepository] as CatRepo
  [SubscriptionRepository] as SubRepo
  [PaymentTransactionRepository] as PayRepo
  [ClientFavoriteRepository] as FavRepo
}

' ════════════════════════════════
' INFRASTRUCTURE
' ════════════════════════════════
package "Infrastructure" #ECEFF1 {
  database "PostgreSQL" as DB
  database "Redis" as Redis
  queue "AWS SQS" as SQS
  cloud "MeiliSearch" as Meili
  cloud "Cloudflare R2" as R2
  cloud "MercadoPago API" as MP
  cloud "dLocal API" as DL
}

' ────── FLOWS ──────

' Controllers → Services
Auth --> AuthSvc
Auth --> SessSvc
Auth --> PwdSvc
Auth --> EmailSvc
Auth --> PhoneSvc

BookClient --> BookCSvc
BookActions --> BookASvc
ProfBook --> BookASvc
BookPay --> BookFinSvc

Billing --> BillSvc
Webhooks --> WHSvc

ProfConfig --> ProfSvc
ProfConfig --> SchedSvc
PubProf --> ProfSvc

Search --> SearchSvc
CatCtrl --> CatSvc
Home --> ProfSvc
Geo --> ProfSvc
Fav --> ProfSvc

' Services → Cache
SearchSvc --> SCache
ProfSvc --> PCache
SlotSvc --> SlCache

' Services → Repos
AuthSvc --> UserRepo
AuthSvc --> SessRepo
BookCSvc --> BookRepo
BookASvc --> BookRepo
ProfSvc --> ProfRepo
ProfSvc --> SvcRepo
SlotSvc --> SlotRepo
CatSvc --> CatRepo
BillSvc --> SubRepo
BookFinSvc --> PayRepo
ProfSvc --> FavRepo

' Repos → DB
UserRepo --> DB
SessRepo --> DB
ProfRepo --> DB
SvcRepo --> DB
BookRepo --> DB
SlotRepo --> DB
CatRepo --> DB
SubRepo --> DB
PayRepo --> DB
FavRepo --> DB

' Cache → Redis
SCache --> Redis
PCache --> Redis
SlCache --> Redis

' External
BillSvc --> MPSvc
MPSvc --> MP
BookProvSvc --> DL
WHSvc --> DL

IdxSvc --> Meili
IdxWorker --> SQS
R2Svc --> R2

' Middleware
OpsFilter -[hidden]-> CookieFilter
CookieFilter -[hidden]-> JwtFilter
JwtFilter -[hidden]-> RateFilter

@enduml
