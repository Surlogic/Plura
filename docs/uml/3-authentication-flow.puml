@startuml "Plura - Authentication Flow"

!theme plain
skinparam defaultFontSize 11

title Plura Backend - Authentication, Sessions & Security Flow

actor "Client\n(Browser / Mobile App)" as Client
participant "CookieOriginProtectionFilter" as CookieFilter
participant "JwtAuthenticationFilter" as JwtFilter
participant "RateLimitingFilter" as RateFilter
participant "AuthController" as AuthCtrl
participant "AuthAbuseProtectionService" as AbuseSvc
participant "AuthService" as AuthSvc
participant "OAuthService" as OAuthSvc
participant "SessionService" as SessionSvc
participant "AuthAuditService" as AuditSvc
database "PostgreSQL" as DB
participant "Google / Apple\nverifiers" as OAuthProviders

== Email / Password Login ==

Client -> CookieFilter : POST /auth/login\nor /auth/login/profesional
CookieFilter -> JwtFilter : skip (no auth cookie required)
JwtFilter -> RateFilter : pass-through
RateFilter -> AuthCtrl : endpoint allowed

AuthCtrl -> AbuseSvc : enforceLoginAllowed(email, ip)
AuthCtrl -> AuthSvc : loginCliente/loginProfesional(request, SessionContext)
AuthSvc -> DB : find user by email\nand deletedAt is null
AuthSvc -> AuthSvc : verify password + role
AuthSvc -> SessionSvc : createSession(user, WEB/MOBILE,\nrefreshHash, userAgent, ip, expiresAt)
SessionSvc -> DB : insert auth_session
AuthSvc -> DB : update user.lastLoginAt /\nlastLoginIp / sessionVersion
AuthSvc -> AuditSvc : log(LOGIN_SUCCESS)
AuthSvc --> AuthCtrl : AuthResult(accessToken,\nrefreshToken, session, user)

note right of AuthCtrl
  Response transport is chosen from
  X-Plura-Session-Transport:
  - default: HttpOnly cookies
  - BODY: tokens in JSON body
end note

AuthCtrl --> Client : 200 OK + cookies/body

== OAuth Login ==

Client -> RateFilter : POST /auth/oauth
RateFilter -> AuthCtrl : pass request
AuthCtrl -> AuthSvc : loginWithOAuth(request, SessionContext)
AuthSvc -> OAuthSvc : verify(provider, code/token,\ncodeVerifier, redirectUri)
OAuthSvc -> OAuthProviders : GoogleTokenVerifier /\nAppleTokenVerifier
OAuthProviders --> OAuthSvc : OAuthUserInfo
AuthSvc -> DB : find user by email or providerId

alt first login or account link
  AuthSvc -> DB : create/update app_user
  note right of AuthSvc
    If desiredRole = PROFESSIONAL,
    AuthService can also create the
    professional profile gateway-side.
  end note
end

AuthSvc -> SessionSvc : createSession(...)
SessionSvc -> DB : insert auth_session
AuthSvc -> AuditSvc : log(LOGIN_SUCCESS)
AuthSvc --> AuthCtrl : AuthResult
AuthCtrl --> Client : 200 OK + cookies/body

== Refresh Session ==

Client -> AuthCtrl : POST /auth/refresh\n(cookie or body refresh token)
AuthCtrl -> AuthSvc : resolveRefreshOwnerId(refreshToken)
AuthCtrl -> AbuseSvc : enforceRefreshAllowed(userId/ip)
AuthCtrl -> AuthSvc : refreshSession(refreshToken, SessionContext)
AuthSvc -> SessionSvc : findTrackedRefreshTokenMatch(hash)

alt tracked current refresh token
  AuthSvc -> SessionSvc : rotateSession(newRefreshHash,\nuserAgent, ip, expiresAt)
  SessionSvc -> DB : update auth_session
  AuthSvc -> AuditSvc : log(REFRESH_SUCCESS)
  AuthSvc --> AuthCtrl : rotated AuthResult
else reused previous refresh token
  AuthSvc -> SessionSvc : markSessionCompromised(session)
  AuthSvc -> SessionSvc : revokeAllSessionsForUser(userId)
  SessionSvc -> DB : revoke auth_session + legacy refresh tokens
  AuthSvc -> AuditSvc : log(REFRESH_FAILURE,\nSESSION_COMPROMISED)
  AuthSvc --> AuthCtrl : 401 SESSION_COMPROMISED
else legacy refresh token fallback
  AuthSvc -> DB : find auth_refresh_token by hash
  AuthSvc -> SessionSvc : migrateLegacyRefreshToken(...)
  SessionSvc -> DB : revoke legacy token + create auth_session
  AuthSvc -> AuditSvc : log(REFRESH_SUCCESS,\nlegacy_refresh_migration)
  AuthSvc --> AuthCtrl : migrated AuthResult
end

AuthCtrl --> Client : rotated cookies/body or 401

== Authenticated API Request ==

Client -> CookieFilter : GET /cliente/** or /profesional/**\nBearer token or auth cookies
CookieFilter -> JwtFilter : validate origin only if request uses auth cookies
JwtFilter -> JwtFilter : extract bearer or plura_access_token
JwtFilter -> DB : load active app_user
JwtFilter -> SessionSvc : findSessionById(sid)
SessionSvc -> DB : load auth_session
JwtFilter -> JwtFilter : validate role + sessionVersion
JwtFilter -> RateFilter : authenticated request
RateFilter --> Client : forward to controller

== Account Recovery & Verification ==

Client -> RateFilter : POST /auth/password/forgot
RateFilter -> AuthCtrl : pass request
AuthCtrl -> AbuseSvc : enforcePasswordResetAllowed(email, ip)
AuthCtrl -> AuthSvc : password reset flow services
AuthCtrl -> Client : 200 Accepted

Client -> AuthCtrl : POST /auth/verify/email/send|confirm\nor /verify/phone/* or /challenge/*
AuthCtrl -> AbuseSvc : enforce per-action limits
AuthCtrl -> DB : persist challenge tables
AuthCtrl -> AuditSvc : log auth audit entries
AuthCtrl --> Client : 200 OK / 204 No Content

@enduml
