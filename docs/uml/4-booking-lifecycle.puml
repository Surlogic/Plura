@startuml "Plura - Booking Lifecycle"

!theme plain
skinparam defaultFontSize 11

title Plura Backend - Booking Lifecycle & Command Flow

state "Booking States" as BookingStates {
  [*] --> PENDING : Client books from public page\nor professional creates booking

  PENDING : Entry / snapshot service + professional data
  PENDING : Entry / persist policySnapshotJson
  PENDING : Entry / init booking_financial_summary
  PENDING : Entry / record BOOKING_CREATED + notifications

  PENDING --> CONFIRMED : manual professional booking\nor professional updates status
  PENDING --> CANCELLED : client / professional cancel

  CONFIRMED : Booking accepted / confirmed
  CONFIRMED : payment session may exist separately
  CONFIRMED --> CANCELLED : client / professional cancel
  CONFIRMED --> COMPLETED : professional marks complete
  CONFIRMED --> NO_SHOW : professional marks no-show

  CANCELLED : side effects:\n- booking_action_decision\n- refund/payout recalculation\n- notifications\n- slot recalculation
  COMPLETED : side effects:\n- payout decision\n- notifications
  NO_SHOW : side effects:\n- financial decision\n- notifications

  CANCELLED --> [*]
  COMPLETED --> [*]
  NO_SHOW --> [*]
}

newpage

title Plura Backend - Public Booking Creation

actor "Cliente" as Client
participant "ProfesionalPublicController\n/public/profesionales/{slug}/reservas" as PublicCtrl
participant "ProfessionalPublicPageService" as PublicPageSvc
participant "BookingService" as BookingFacade
participant "BookingCommandApplicationService" as BookingCmdApp
participant "ProfessionalAccessSupport" as AccessSupport
participant "BookingSchedulingAvailabilityGateway" as Availability
participant "BookingPolicySnapshotService" as PolicySvc
participant "BookingRepository" as BookingRepo
participant "BookingFinanceService" as FinanceSvc
participant "BookingEventService" as EventSvc
participant "BookingNotificationIntegrationService" as NotificationSvc
participant "ProfessionalSideEffectCoordinator" as SideEffects
database "PostgreSQL" as DB

Client -> PublicCtrl : POST /public/profesionales/{slug}/reservas
PublicCtrl -> PublicPageSvc : createPublicBooking(slug, request, userId)
PublicPageSvc -> BookingFacade : createPublicBooking(...)
BookingFacade -> BookingCmdApp : createPublicBooking(...)

BookingCmdApp -> AccessSupport : loadActiveUser(userId)\nensure USER
BookingCmdApp -> DB : lock professional by slug
BookingCmdApp -> DB : load professional_service
BookingCmdApp -> Availability : isSlotAvailable(professionalId,\nserviceId, startDateTime)

alt slot unavailable
  Availability --> BookingCmdApp : false
  BookingCmdApp --> PublicCtrl : 409 Conflict
  PublicCtrl --> Client : horario no disponible
end

BookingCmdApp -> PolicySvc : buildForProfessionalId(profileId)
BookingCmdApp -> BookingRepo : saveAndFlush(booking PENDING\nwith snapshots)
BookingRepo -> DB : insert booking
BookingCmdApp -> FinanceSvc : ensureInitialized(booking)
BookingCmdApp -> EventSvc : record(BOOKING_CREATED)
BookingCmdApp -> NotificationSvc : recordBookingCreated(...)
BookingCmdApp -> SideEffects : onBookingChanged(profile, date)
BookingCmdApp --> PublicCtrl : PublicBookingResponse
PublicCtrl --> Client : 201 Created

note right of BookingCmdApp
  The booking is created first.
  Payment is not opened here anymore.
  The client can request a payment session later
  via /cliente/reservas/{id}/payment-session.
end note

newpage

title Plura Backend - Payment Session, Idempotency & Booking Commands

actor "Cliente / Profesional" as Actor
participant "BookingPaymentController\n/cliente/reservas/{id}/payment-session" as PaymentCtrl
participant "BookingPaymentApplicationService" as PaymentApp
participant "BookingProviderIntegrationService" as ProviderSvc
participant "ClientBookingCommandController /\nProfessionalBookingCommandController" as CommandCtrl
participant "BookingCommandIdempotencyService" as IdempotencySvc
participant "BookingService" as BookingSvc
participant "BookingCommandApplicationService" as CommandApp
participant "BookingActionDecisionService" as DecisionSvc
participant "BookingFinanceService" as FinanceSvc2
participant "BookingEventService" as EventSvc2
participant "BookingNotificationIntegrationService" as NotificationSvc2
participant "BookingPayoutApplicationService" as PayoutApp
database "PostgreSQL" as DB2

== Optional payment session ==

Actor -> PaymentCtrl : POST /cliente/reservas/{id}/payment-session
PaymentCtrl -> PaymentApp : createPaymentSessionForClient(...)
PaymentApp -> ProviderSvc : createPaymentSessionForClient(...)
ProviderSvc -> DB2 : create/update payment_transaction
ProviderSvc --> PaymentCtrl : payment URL / checkout payload
PaymentCtrl --> Actor : 200 OK

== Cancel / Reschedule / No-show / Complete ==

Actor -> CommandCtrl : POST cancel/reschedule/no-show/complete\n(+ optional Idempotency-Key)
CommandCtrl -> IdempotencySvc : execute(actionType, actorType,\nactorUserId, bookingId, key, payload)

alt repeated completed request with same key + payload
  IdempotencySvc -> DB2 : read booking_command_idempotency_record
  IdempotencySvc --> CommandCtrl : stored BookingCommandResponse
  CommandCtrl --> Actor : 200 OK (replayed)
else first execution
  IdempotencySvc -> DB2 : insert IN_PROGRESS record
  IdempotencySvc -> BookingSvc : delegate command
  BookingSvc -> CommandApp : cancel/reschedule/no-show/complete
  CommandApp -> DB2 : lock booking + validate ownership
  CommandApp -> DecisionSvc : record booking_action_decision
  CommandApp -> FinanceSvc2 : applyDecision(...)
  CommandApp -> EventSvc2 : record booking_event
  CommandApp -> NotificationSvc2 : record notification events

  opt payout / refund dispatch after commit
    CommandApp -> PayoutApp : retry or dispatch payout flows
    PayoutApp -> ProviderSvc : provider operations
  end

  BookingSvc --> IdempotencySvc : BookingCommandResponse
  IdempotencySvc -> DB2 : mark COMPLETED + store response JSON
  IdempotencySvc --> CommandCtrl : BookingCommandResponse
  CommandCtrl --> Actor : 200 OK
end

@enduml
