@startuml "Plura - Infrastructure"

!theme plain
skinparam defaultFontSize 11
skinparam componentStyle rectangle

title Plura Backend — Infrastructure & External Services

' ════════════════════════════════
' COMPONENTS
' ════════════════════════════════

package "Spring Boot Application" as App #E8F5E9 {

  package "Cache Layer" #FFF3E0 {
    component "SearchCacheService" as SCS
    component "ProfileCacheService" as PCS
    component "SlotCacheService" as SlCS
    component "CacheServiceFacade\n(async invalidation)" as CSF
  }

  package "Search Engine" #E3F2FD {
    component "SearchService" as SS
    component "SearchIndexService" as SIS
    component "SearchIndexWorker\n(async indexing)" as SIW
  }

  package "Job Queue" #F3E5F5 {
    component "SqsJobQueueService" as SQSSvc
    component "JobIdempotencyService" as JIS
    component "ImageThumbnailJobService" as ITJS
  }

  package "Storage" #FFEBEE {
    component "ImageStorageService\n<<interface>>" as ISS
    component "CloudflareR2ImageStorageService" as R2S
    component "LocalImageStorageService" as LS
    ISS <|.. R2S
    ISS <|.. LS
  }

  package "Payment Providers" #E0F7FA {
    component "PaymentProviderClient\n<<interface>>" as PPC
    component "MercadoPagoPaymentProviderClient" as MPC
    component "DLocalPaymentProviderClient" as DLC
    PPC <|.. MPC
    PPC <|.. DLC

    component "BillingWebhookService" as BWS
    component "PaymentEventLedgerService" as PELS
  }

  package "Scheduled Tasks" #FFF9C4 {
    component "AvailableSlotScheduler\n(cron: every 30 min, 2-6 AM)" as ASS
    component "ScheduleSummaryScheduler\n(cron: every 30 min)" as SSS
    component "AvailableSlotBootstrap\n(on startup)" as ASB
  }

  package "Geo Services" #DCEDC8 {
    component "GeoService\n(autocomplete, geocode)" as GS
  }

  package "Email/SMS" #FCE4EC {
    component "Spring Mail\n(SMTP)" as Mail
  }
}

' ════════════════════════════════
' EXTERNAL SERVICES
' ════════════════════════════════

cloud "External Services" {
  database "PostgreSQL\n(primary store)" as PG #B3E5FC
  database "Redis\n(optional cache)" as Redis #FFCDD2
  queue "AWS SQS\n+ Dead Letter Queue" as SQS #E1BEE7
  component "MeiliSearch\n(search engine)" as Meili #BBDEFB
  storage "Cloudflare R2\n(image storage)" as R2 #B2DFDB
  component "MercadoPago API\n(subscriptions)" as MP #FFE0B2
  component "dLocal API\n(payments/payouts)" as DL #FFE0B2
  component "SMTP Server\n(email)" as SMTP #F8BBD0
  storage "Local Filesystem\n(dev fallback)" as LFS #ECEFF1
}

' ════════════════════════════════
' CONNECTIONS
' ════════════════════════════════

' Cache connections
SCS --> Redis : cache search results\n(TTL: 300s)
PCS --> Redis : cache profiles\n(TTL: 300s)
SlCS --> Redis : cache available slots\n(TTL: 300s)

note right of Redis
  Fallback: Caffeine in-memory
  • Search: 20,000 entries
  • Profiles: 10,000 entries
  • Slots: 30,000 entries
end note

' Search connections
SIS --> Meili : index/query\nHTTP API
SIW --> SQS : consume SEARCH_INDEX jobs

' Job queue
SQSSvc --> SQS : send/receive messages
ITJS --> SQS : consume THUMBNAIL_IMAGE jobs

note right of SQS
  Job Types:
  • THUMBNAIL_IMAGE
  • SCHEDULE_SUMMARY
  • SEARCH_INDEX

  DLQ for failed jobs
end note

' Storage
R2S --> R2 : upload/download\nS3-compatible API
LS --> LFS : upload/download\n(dev only)

note right of R2
  Max upload: 5 MB
  Allowed: JPEG, PNG,
  WebP, AVIF
  Pre-signed URLs: 10 min
end note

' Payments
MPC --> MP : create subscriptions\ncancel, get status
DLC --> DL : payments, payouts\nrefunds, splits
BWS --> MP : receive webhooks
BWS --> DL : receive webhooks

note bottom of MP
  Webhook: /webhooks/mercadopago
  Signature verification
end note

note bottom of DL
  Webhook: /webhooks/dlocal
  HMAC signature verification
  Payout OAuth flow
end note

' Database
App --> PG : JPA/Hibernate\nHikariCP pool\n(max: 100 connections)

note right of PG
  Flyway migrations: V1 → V40
  Connection pool:
  • Max: 100
  • Min idle: 10
  • Timeout: 30s
end note

' Email
Mail --> SMTP : send verification,\nreset, notifications

' Scheduled tasks
ASS --> PG : rebuild slots\n(30 days ahead)
SSS --> PG : compute summaries\n(14 days ahead)
ASB --> PG : bootstrap slots\n(7 days, on startup)

' ════════════════════════════════
' DEPLOYMENT NOTES
' ════════════════════════════════

note as N1
  **Rate Limiting (Bucket4j)**
  Applied per endpoint/user
  via RateLimitingFilter

  **Security Headers**
  • HSTS: 1 year + preload
  • X-Content-Type-Options: nosniff
  • X-Frame-Options: sameorigin
  • Referrer-Policy: strict-origin

  **Monitoring**
  • Spring Actuator
  • Prometheus metrics
  • /internal/ops/** (token-protected)
end note

@enduml
