{
  "name": "plura",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node ./scripts/predev.cjs 3000 && node ./scripts/predev.cjs 3002",
    "dev": "concurrently --kill-others-on-fail --names web,api \"pnpm -C apps/web dev\" \"pnpm dev:backend-java\"",
    "dev:web": "pnpm -C apps/web dev",
    "dev:mobile": "pnpm -C apps/mobile start",
    "android:mobile": "pnpm -C apps/mobile android",
    "dev:backend": "pnpm dev:backend-java",
    "dev:backend-java": "node ./scripts/dev-backend-java.cjs",
    "dev:backend:remote": "cd backend-java && SPRING_FLYWAY_VALIDATE_ON_MIGRATE=false ./gradlew bootRun",
    "build": "pnpm -r build",
    "build:backend-java": "node ./scripts/dev-backend-java.cjs build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3"
  },
  "pnpm": {
    "overrides": {
      "@xmldom/xmldom@>=0.8.0 <0.8.13": "0.8.13",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=5.0.0 <5.0.5": "5.0.6",
      "fast-uri@>=3.0.0 <3.1.2": "3.1.2",
      "flatted@<3.4.2": "3.4.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=9.0.0 <9.0.7": "9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "10.2.5",
      "node-forge@>=1.0.0 <1.4.0": "1.4.0",
      "picomatch@>=2.0.0 <2.3.2": "2.3.2",
      "picomatch@>=3.0.0 <3.0.2": "3.0.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "postcss@<8.5.14": "8.5.14",
      "protocol-buffers-schema@<3.6.1": "3.6.1",
      "tar@>=7.0.0 <7.5.15": "7.5.15",
      "undici@>=6.0.0 <6.25.0": "6.25.0",
      "yaml@>=2.0.0 <2.9.0": "2.9.0"
    }
  }
}
