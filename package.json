{
  "name": "plura",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names web,api \"pnpm -C apps/web dev\" \"cd backend-java && ./gradlew bootRun\"",
    "dev:web": "pnpm -C apps/web dev",
    "dev:backend": "cd backend-java && ./gradlew bootRun",
    "dev:backend-java": "cd backend-java && ./gradlew bootRun",
    "build": "pnpm -r build",
    "build:backend-java": "cd backend-java && ./gradlew build",
    "lint": "pnpm -r lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
